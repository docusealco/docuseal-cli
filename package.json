{
  "name": "@docuseal/cli",
  "version": "1.0.0",
  "description": "DocuSeal CLI — manage templates, submissions, and submitters from the terminal",
  "type": "module",
  "bin": {
    "docuseal": "./bin/run.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --outfile=dist/index.js --platform=node --format=esm --packages=external",
    "prepublishOnly": "npm run build",
    "sync-spec": "tsx scripts/sync-spec.ts"
  },
  "files": [
    "dist",
    "bin"
  ],
  "oclif": {
    "bin": "docuseal",
    "dirname": "docuseal",
    "topicSeparator": " "
  },
  "keywords": [
    "docuseal",
    "cli",
    "esign",
    "pdf",
    "signing",
    "documents"
  ],
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.27.4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "dependencies": {
    "@oclif/core": "^4.10.0",
    "yaml": "^2.8.2"
  }
}
